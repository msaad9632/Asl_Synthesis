*.mp4
*.mov
*.avi
*.webm
*.mkv

# --- Python caches ---
__pycache__/
*.pyc

# --- Logs ---
*.log

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/

